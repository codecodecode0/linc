# ---------------------------------------------------------------------------
# linc backend configuration
#
# Copy to `.env` and fill in once you have developer apps. Each provider runs
# in MOCK mode until its credentials are set, so the connect flow and insights
# return realistic sample data with no apps configured.
#
# OAuth redirect URIs are derived automatically as:
#   {API_BASE_URL}/api/auth/{platform}/callback
# Register these in each provider's app:
#   {API_BASE_URL}/api/auth/instagram/callback
#   {API_BASE_URL}/api/auth/youtube/callback
# ---------------------------------------------------------------------------

# --- Instagram (Meta) — placeholders, provide later ---
META_APP_ID=
META_APP_SECRET=
META_API_VERSION=v21.0
META_SCOPES=instagram_basic,instagram_manage_insights,pages_show_list,pages_read_engagement

# --- YouTube (Google) — placeholders, provide later ---
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_SCOPES=https://www.googleapis.com/auth/youtube.readonly,https://www.googleapis.com/auth/yt-analytics.readonly

# --- App URLs ---
FRONTEND_URL=http://localhost:8000
API_BASE_URL=http://localhost:8000

# --- CORS — comma-separated origins, or * for all (dev only) ---
CORS_ORIGINS=*

# --- Database — not used yet. Set when moving to Postgres, then switch the
#     repository wiring in app/deps.py. Example:
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/linc
DATABASE_URL=
